# Research-Nexus Pro 环境变量配置
# 复制此文件为 .env 并填写你的配置

# ============================================
# Cognee LLM API 配置 (可选)
# 用于AI分析和知识图谱构建
# ============================================

# OpenAI API Key (用于Cognee智能分析)
# COGNEE_LLM_API_KEY=sk-your-openai-api-key-here

# 可选：使用其他LLM提供商
# COGNEE_LLM_PROVIDER=openai
# COGNEE_LLM_MODEL=gpt-4

# ============================================
# 后端服务配置
# ============================================

# 后端服务端口
BACKEND_PORT=8000

# 日志级别 (debug, info, warning, error)
LOG_LEVEL=info

# ============================================
# 前端服务配置
# ============================================

# 前端开发服务器端口
FRONTEND_PORT=5173

# API基础URL (生产环境使用)
# VITE_API_BASE_URL=http://localhost:8000/api

# ============================================
# 数据库配置 (可选)
# ============================================

# Neo4j 图数据库 (用于高级图谱功能)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=password

# Qdrant 向量数据库 (用于语义搜索)
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# ============================================
# 开发配置
# ============================================

# 启用热重载
HOT_RELOAD=true

# 调试模式
DEBUG=false
